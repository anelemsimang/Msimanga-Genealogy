# ---------------------------------------------------------------------------
# Lineage — environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings → API). Never commit `.env.local`.
# ---------------------------------------------------------------------------

# Public — safe to expose to the browser (protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only — NEVER expose to the browser. Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL of the deployed app (used for invite/magic links). Optional in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Used by `npm run seed` to create your admin account (never commit real values).
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_NAME=Your Name
